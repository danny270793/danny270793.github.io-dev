---
import { Image } from "astro:assets";
import Me from "../libraries/me";
import profilePicture from "../images/profile.jpg";
import headerBackground from "../images/parallax/header.jpg";
---

<div
  class="parallax header w3-display-container"
  style={`background-image: url("${headerBackground.src}")`}
>
  <div class="w3-display-middle" style="text-align: center;">
    <span
      class="w3-center w3-padding w3-black w3-xlarge w3-wide w3-animate-opacity"
      style="display: block;"
    >
      Danny Vaca
    </span>
    <p class="w3-center w3-padding w3-black w3-animate-opacity hero-subtitle">
      Senior Full Stack Developer
    </p>
  </div>
</div>

<div id="about-me" class="w3-content w3-container w3-padding-64 fade-in">
  <h3 class="section-title">About me</h3>
  <hr class="section-divider" />
  <div class="w3-row">
    <div class="w3-third w3-center">
      <Image
        class="w3-circle w3-padding"
        src={profilePicture}
        alt="Profile picture"
        width={300}
        height={300}
        style="width: 100%; height: auto;"
      />
    </div>
    <div class="w3-twothird w3-padding">
      {
        Me.detail.split("\n").map((e) => (
          <>
            {e}
            <br />
            <br />
          </>
        ))
      }
    </div>
  </div>
</div>
