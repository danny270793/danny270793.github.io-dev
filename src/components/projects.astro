---
import { Image } from "astro:assets";
import ProjectsBackground from "../images/parallax/projects.jpg";
import GooglePlay from "../images/projects/google-play.png";
import AppStore from "../images/projects/app-store.png";
import MyProjects from "../libraries/me/knowledges/projects";
import type { Project } from "../libraries/me/knowledges/projects";
import Github from "../images/projects/github.png";
---

<div
  id="projects"
  class="parallax separator w3-display-container"
  style={`background-image: url("${ProjectsBackground.src}")`}
>
  <div class="w3-display-middle no-spaces">
    <span
      class="w3-center w3-padding w3-black w3-xlarge w3-wide w3-animate-opacity"
      data-i18n="sections.projects"
    >
      Projects
    </span>
  </div>
</div>

<div class="section-bg-alt">
  <div class="w3-content w3-container w3-padding-64 fade-in">
  <div class="projects-grid">
    {MyProjects.map((project: Project) => (
      <div class="project-card">
        <div class="project-card-image">
          <Image
            src={project.image}
            alt={project.name}
            width={64}
            height={64}
            style="width: 64px; height: 64px; object-fit: contain; border-radius: 12px;"
          />
        </div>
        <div class="project-card-body">
          <h5 class="project-card-name">{project.name}</h5>
          <p class="project-card-desc">{project.description}</p>
          <div class="project-card-links">
            {project.playstore && (
              <a href={project.playstore} target="_blank" rel="noopener noreferrer" class="project-store-link" aria-label="Google Play">
                <Image src={GooglePlay} alt="Google Play" width={120} height={35} style="height: 26px; width: auto;" />
              </a>
            )}
            {project.appstore && (
              <a href={project.appstore} target="_blank" rel="noopener noreferrer" class="project-store-link" aria-label="App Store">
                <Image src={AppStore} alt="App Store" width={120} height={35} style="height: 26px; width: auto;" />
              </a>
            )}
            {project.github && (
              <a href={project.github} target="_blank" rel="noopener noreferrer" class="project-store-link" aria-label="GitHub">
                <Image src={Github} alt="GitHub" width={90} height={28} style="height: 26px; width: auto;" />
              </a>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
  </div>
</div>
