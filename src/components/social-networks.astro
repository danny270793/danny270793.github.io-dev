---
import { Image } from "astro:assets";
import SocialLinks from "../libraries/me/social-links";
import type { SocialLink } from "../libraries/me/social-links";

const year = new Date().getFullYear();
---

<footer id="social-networks" class="site-footer">
  <div class="footer-inner">
    <div class="footer-social">
      {
        SocialLinks.map((socialLink: SocialLink) => (
          <a
            href={socialLink.link}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label={socialLink.alternativeText}
          >
            <Image
              src={socialLink.image}
              alt={socialLink.alternativeText}
              width={120}
              height={28}
              style="height: 28px; width: auto; border-radius: 4px;"
            />
          </a>
        ))
      }
    </div>
    <p class="footer-copy">
      &copy; {year} Danny Vaca &middot; <span data-i18n="footer.rights">All rights reserved</span>
    </p>
  </div>
</footer>
