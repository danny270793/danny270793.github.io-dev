---
import TechnologiesBackground from "../images/parallax/technologies.jpg";
import MyTechnologies from "../libraries/me/knowledges/technologies";
import type { Technology } from "../libraries/me/knowledges/technologies";

const categories = [...new Set(MyTechnologies.map((e: Technology) => e.category))];
---

<div
  id="technologies"
  class="parallax separator w3-display-container"
  style={`background-image: url("${TechnologiesBackground.src}")`}
>
  <div class="w3-display-middle no-spaces">
    <span
      class="w3-center w3-padding w3-black w3-xlarge w3-wide w3-animate-opacity"
      data-i18n="sections.technologies"
    >
      Technologies
    </span>
  </div>
</div>

<div class="section-bg-alt">
  <div class="w3-content w3-container w3-padding-64 fade-in">
    <h3 class="section-title" data-i18n="sections.technologies">Technologies</h3>
    <hr class="section-divider" />

    <div class="tech-grid">
      {categories.map((category) => {
        const items = MyTechnologies.filter((t: Technology) => t.category === category);
        return (
          <div class="tech-category-card">
            <div class="tech-category-header">
              <span class="tech-category-name">{category}</span>
              <span class="tech-category-count">{items.length}</span>
            </div>
            <div class="tech-badges-area">
              {items.map((technology: Technology) => (
                <span class="tech-badge">
                  <img src={technology.link} alt={technology.alternative} loading="lazy" />
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</div>
