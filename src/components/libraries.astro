---
import MyLibraries from "../libraries/me/knowledges/libraries";
import type { Library } from "../libraries/me/knowledges/libraries";
import OpenSourceLibrariesBackground from "../images/parallax/open source libraries.jpg";
import { Image } from "astro:assets";
---

<div
  id="open-source-libraries"
  class="parallax separator w3-display-container"
  style={`background-image: url("${OpenSourceLibrariesBackground.src}")`}
>
  <div class="w3-display-middle no-spaces">
    <span
      class="w3-center w3-padding w3-black w3-xlarge w3-wide w3-animate-opacity"
      data-i18n="sections.libraries"
    >
      Open Source Libraries
    </span>
  </div>
</div>

  <div class="w3-content w3-container w3-padding-64 fade-in">
    <h3 class="section-title" data-i18n="sections.libraries">Open Source Libraries</h3>
    <hr class="section-divider" />

    <div class="projects-grid">
      {MyLibraries.map((library: Library) => (
        <a
          href={library.link}
          target="_blank"
          rel="noopener noreferrer"
          class="project-card project-card-link"
        >
          <div class="project-card-image">
            <Image
              src={library.image}
              alt={library.name}
              width={64}
              height={64}
              style="width: 64px; height: 64px; object-fit: contain; border-radius: 12px;"
            />
          </div>
          <div class="project-card-body">
            <h5 class="project-card-name">{library.name}</h5>
            <p class="project-card-desc">{library.description}</p>
            <span class="library-type-badge">{library.type}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
